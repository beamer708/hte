# ─── Unity Vault — Required Environment Variables ───────────────────────────
#
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
#
# For Vercel: add each variable in Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Discord OAuth2 (server-side only — never expose to client) ────────────────
#
# DISCORD_REDIRECT_URI must EXACTLY match what is registered in:
#   Discord Developer Portal → Application → OAuth2 → Redirects
#
# The redirect URI is always: {NEXTAUTH_URL}/api/auth/callback/discord
# Example (production):  https://unityvault.xyz/api/auth/callback/discord
# Example (development):  http://localhost:3000/api/auth/callback/discord
#
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://yourdomain.com/api/auth/callback/discord

# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://yourdomain.com

# ── Discord Server / Admin ────────────────────────────────────────────────────
DISCORD_GUILD_ID=
DISCORD_ADMIN_ROLE_ID=1485445645270515825
DISCORD_BETA_TESTER_ID=1485237738277175457

# ── Discord Webhooks ──────────────────────────────────────────────────────────
# Each webhook URL must be created in Discord Server Settings → Integrations → Webhooks
DISCORD_SUGGESTION_WEBHOOK=https://discord.com/api/webhooks/...
DISCORD_APPLICATION_WEBHOOK=https://discord.com/api/webhooks/...
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── AI Assistant ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Database (Prisma / PostgreSQL) ────────────────────────────────────────────
DATABASE_URL=postgres://...

# ── Discord Bot API Forwarding (optional fallback) ────────────────────────────
BOT_API_URL=https://your-bot-host-url.com
API_SECRET=replace_with_secure_random_32_char_string

# ── Analytics ─────────────────────────────────────────────────────────────────
ANALYTICS_SALT=change_me

# ── Site Features ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_SHUTDOWN=false
NEXT_PUBLIC_STAFF_APPLICATION_OPEN=true
STAFF_APPLICATION_OPEN=true
