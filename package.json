{
  "name": "howtoerlc-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "rm -f .next/dev/lock && WATCHPACK_POLLING=true NODE_OPTIONS=--max-old-space-size=4096 next dev --webpack -H 127.0.0.1",
    "dev:clean": "rm -rf .next && WATCHPACK_POLLING=true NODE_OPTIONS=--max-old-space-size=4096 next dev --webpack -H 127.0.0.1",
    "build": "prisma generate && next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "eslint app components lib proxy.ts next.config.js prisma.config.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma db push && tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "@flaticon/flaticon-uicons": "^3.3.1",
    "@prisma/client": "^6.19.2",
    "@vercel/speed-insights": "^1.3.1",
    "next": "^16.1.6",
    "next-auth": "^4.24.13",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.17",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.4.33",
    "prisma": "^6.19.2",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.0",
    "typescript": "^5.3.3"
  }
}
